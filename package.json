{
  "name": "real-estate-next-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "clean": "rm -rf .next",
    "dev:clean": "rm -rf .next && next dev",
    "build": "npm run build:compile && npm run build:generate",
    "build:compile": "next build --webpack --experimental-build-mode compile",
    "build:generate": "next build --webpack --experimental-build-mode generate",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@fontsource/manrope": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "framer-motion": "^12.9.1",
    "lucide-react": "^0.511.0",
    "next": "^16.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.7",
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.27.0",
    "eslint-config-next": "^16.2.3",
    "eslint-config-prettier": "^10.1.5",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3"
  }
}
